LINE_CHANNEL_SECRET=eabc6fdf1ec01323424bec4147e1b071
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
HOST_DATA_DIR=/absolute/path/to/alice-office-router/data

# Set to false when running router on localhost (not inside Docker)
ROUTER_IN_DOCKER=true

# Real Hermes Agent image (its api_server platform answers requests; the
# router owns all LINE communication, not Hermes's own LINE plugin)
HERMES_IMAGE=nousresearch/hermes-agent

# Shared bearer secret between the router and every Hermes container's
# api_server platform. Generate with: openssl rand -hex 32
HERMES_API_SERVER_KEY=change-me

# LLM endpoint — templated into each room's config.yaml (providers.custom)
LLM_BASE_URL=change-me
LLM_API_KEY=change-me
LLM_MODEL=change-me

# Optional: Google Places API (New) key for secretary-mcp's maps_search /
# maps_details tools. Forwarded into every Hermes container so the MCP server
# can call Google Maps. Leave blank to disable maps tools (they return a
# config error when called). Get a key at https://console.cloud.google.com/
# (enable "Places API (New)").
# GOOGLE_MAPS_API_KEY=

# ── Default plugins ──────────────────────────────────────────────────────
# Plugins in ./plugins/ are volume-mounted (read-only) into every Hermes
# container at /opt/data/plugins/. The names below are written into each
# new room's config.yaml under plugins.enabled.
# DEFAULT_PLUGINS=local-tools

# For production, build the derivative image with local-tools dependencies:
#   docker build -f Dockerfile.hermes -t alice-hermes-agent:v1 .
# Then set HERMES_IMAGE=alice-hermes-agent:v1 instead of the upstream image.

# ── secretary-mcp dev override ───────────────────────────────────────────
# Dev only. secretary-mcp/server.mjs + tools/ are normally baked into the
# Hermes image (Dockerfile.hermes). Set this to the absolute host path of
# ./secretary-mcp to bind-mount source over the image's copy — edits take
# effect on `docker restart hermes_<room_id>`, no rebuild needed.
# node_modules stays the image's baked-in copy either way. Leave blank in
# production (customer hosts don't have this repo's source tree).
# HOST_SECRETARY_MCP_DIR=/absolute/path/to/alice-office-router/secretary-mcp
