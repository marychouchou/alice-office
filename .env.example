# LINE Webhook 簽章驗證用的 Channel Secret。本地開發可填任意假字串——
# scripts/test_webhook.py 會用同一個值計算簽章，不需要真的 LINE 憑證；
# 只有接真的 LINE 驗收（見 README「接真的 LINE」）才需要換成 LINE Developers
# Console 給的真值。
LINE_CHANNEL_SECRET=change-me

# Router 呼叫 LINE Reply/Push Message API 用的 Channel Access Token。
# 同上，本地測試（假 user id）填任意假字串即可；只有要把回覆推播給
# 真實 LINE 使用者時才需要真值。
LINE_CHANNEL_ACCESS_TOKEN=change-me

# 宿主機上 data/ 的絕對路徑，Docker 掛載 volume 時需要用到。填你 clone
# 這個 repo 的實際絕對路徑，例如 /Users/xxx/alice-office-router/data。
HOST_DATA_DIR=change-me

# Set to false when running router on localhost (not inside Docker);
# true (容器化部署) is the default here since docker-compose mounts
# ./src/hermes automatically — host-mode dev must override to false.
ROUTER_IN_DOCKER=true

# Router's own read/write path for room data (mkdir, config.yaml). Defaults to
# /app/data, which is correct when the router itself also runs in a container
# (that's where the volume is mounted). Host-mode dev (ROUTER_IN_DOCKER=false)
# MUST override this to the same absolute path as HOST_DATA_DIR above, or the
# router will try to mkdir /app/data on the host (usually missing/unwritable)
# and silently fail to create any room — see README troubleshooting.
# DATA_DIR=/absolute/path/to/alice-office-router/data

# Router-local path to this repo's src/hermes/ directory (mcp/<name>/ and
# plugin/<name>/ source templates). Each room's first container creation
# seeds a private, room-editable copy of every template into its own data
# dir (data/<room_id>/mcp/, data/<room_id>/plugins/) — see
# container_manager.py _ensure_mcp_seed / _ensure_plugin_seed. Defaults to
# /app/hermes-templates, which is correct when the router itself also runs
# in a container (docker-compose mounts ./src/hermes there). Host-mode dev
# (ROUTER_IN_DOCKER=false) MUST override this to the same absolute path
# pattern as DATA_DIR above — the repo's real src/hermes path.
# HERMES_TEMPLATES_DIR=/absolute/path/to/alice-office-router/src/hermes

# Real Hermes Agent image (its api_server platform answers requests; the
# router owns all LINE communication, not Hermes's own LINE plugin)
HERMES_IMAGE=nousresearch/hermes-agent

# Shared bearer secret between the router and every Hermes container's
# api_server platform. Generate with: openssl rand -hex 32
HERMES_API_SERVER_KEY=change-me

# LLM endpoint — templated into each room's config.yaml (providers.custom)
LLM_BASE_URL=change-me
LLM_API_KEY=change-me
LLM_MODEL=change-me

# ── Default plugins ──────────────────────────────────────────────────────
# Templates in src/hermes/plugin/ are seeded (once, per room — see
# HERMES_TEMPLATES_DIR above) into each room's own data/<room_id>/plugins/.
# The names below are written into each new room's config.yaml under
# plugins.enabled; they must match a seeded plugin directory name.
# DEFAULT_PLUGINS=local-tools

# For production, build the derivative image with plugin/MCP dependencies:
#   docker build -f Dockerfile.hermes -t alice-hermes-agent:v1 .
# Then set HERMES_IMAGE=alice-hermes-agent:v1 instead of the upstream image.

# ── Per-MCP secrets ───────────────────────────────────────────────────────
# Each MCP template under src/hermes/mcp/<name>/ has its own .env.example
# (e.g. src/hermes/mcp/secretary/.env.example — GOOGLE_MAPS_API_KEY, etc.).
# There's nothing to set here in this repo-level .env: once a room's
# container is first created, _ensure_mcp_seed copies that .env.example into
# the room's own data/<room_id>/mcp/<name>/.env, and server.mjs loads it
# itself — edit that per-room file directly to change that room's secrets;
# this repo's Settings never sees its contents.
